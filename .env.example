# Telegram Bot Token (احصل عليه من @BotFather)
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Your Telegram User ID
ALLOWED_USER_IDS=123456789

# Database
DATABASE_URL=sqlite:///./trading_bot.db

# --- Trading Defaults ($50 Small Capital Mode) ---
DEFAULT_CAPITAL=50
DEFAULT_RISK_PERCENT=0.5
DEFAULT_MIN_CONFIDENCE=85
DEFAULT_MAX_LEVERAGE=10
DEFAULT_MAX_TRADES_PER_DAY=3
DEFAULT_TRADING_TYPE=scalping
MAX_CONSECUTIVE_LOSSES=2
SMALL_CAPITAL_MODE=True
SMALL_CAPITAL_THRESHOLD=200
QUICK_SCALP_MIN_CONFIDENCE=90
REGULAR_SCALP_MIN_CONFIDENCE=85
MAX_SPREAD_SCALP=30
MIN_ENTRY_RISK_REWARD=1.5

# --- Analysis ---
ANALYSIS_INTERVAL_MINUTES=15
ENABLE_AUTO_ANALYSIS=True

# --- MT5 (تشغيل مباشر من ميتاتريدر - يتطلب تثبيت) ---
MT5_ENABLED=True
MT5_SYMBOL=XAUUSD
MT5_TIMEOUT_SECONDS=30

# --- OANDA API (بديل MT5 - مجاني, دقيق, يعمل على السحابة) ---
# سجل حساب ديمو في OANDA واحصل على API Token من: https://developer.oanda.com/
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_INSTRUMENT=XAU_USD

# --- Webhook / API ---
WEBHOOK_PORT=8080

# --- API Keys (للبطء - اختياري) ---
ALPHA_VANTAGE_KEY=
NEWS_API_KEY=
FRED_API_KEY=

# --- Logging ---
LOG_LEVEL=INFO
