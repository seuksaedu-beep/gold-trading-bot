# Telegram Bot Token (احصل عليه من @BotFather)
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Your Telegram User ID
ALLOWED_USER_IDS=123456789

# Database
DATABASE_URL=sqlite:///./trading_bot.db

# --- Trading Defaults ---
DEFAULT_CAPITAL=10000
DEFAULT_RISK_PERCENT=1.5
DEFAULT_MIN_CONFIDENCE=80
DEFAULT_MAX_LEVERAGE=10
DEFAULT_MAX_TRADES_PER_DAY=3
DEFAULT_TRADING_TYPE=swing
MAX_CONSECUTIVE_LOSSES=2

# --- Analysis ---
ANALYSIS_INTERVAL_MINUTES=15
ENABLE_AUTO_ANALYSIS=True

# --- MT5 (تشغيل مباشر من ميتاتريدر) ---
MT5_ENABLED=True
MT5_SYMBOL=XAUUSD
MT5_TIMEOUT_SECONDS=30

# --- Webhook / API ---
WEBHOOK_PORT=8080

# --- API Keys (للبطء - اختياري) ---
ALPHA_VANTAGE_KEY=
NEWS_API_KEY=
FRED_API_KEY=

# --- Logging ---
LOG_LEVEL=INFO
